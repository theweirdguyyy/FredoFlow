# ─── apps/server/.env ───
DATABASE_URL="postgresql://user:password@localhost:5432/fredoflow"
JWT_ACCESS_SECRET="fredoflow-access-secret-min-32-chars-here"
JWT_REFRESH_SECRET="fredoflow-refresh-secret-min-32-chars-here"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLIENT_URL="http://localhost:3000"
PORT=5000

# ─── apps/web/.env.local ───
NEXT_PUBLIC_API_URL="http://localhost:5000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:5000"
NEXT_PUBLIC_APP_NAME="FredoFlow"
